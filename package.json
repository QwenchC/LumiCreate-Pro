{
  "name": "lumicreate-local",
  "version": "1.0.0",
  "description": "LumiCreate Local - Comic drama generation tool",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "cd renderer && npm run build",
    "prebuild": "node prebuild-wincscode.js",
    "build": "npm run build:renderer && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "build:installer": "npm run build:renderer && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "preview": "electron ."
  },
  "build": {
    "appId": "com.lumicreate.local",
    "productName": "LumiCreate-Local",
    "directories": {
      "output": "dist-app"
    },
    "win": {
      "target": "nsis",
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateSubjectName": null,
      "rfc3161TimeStampServer": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ]
  },
  "keywords": [
    "comic",
    "manga",
    "ai",
    "generation"
  ],
  "author": "LumiCreate Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  }
}

lized_name":"遮罩","name":"MASK","type":"MASK","links":null}],"properties":{"cnr_id":"comfy-core","ver":"0.20.1","Node name for S&R":"LoadImage","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.8"}},"widgets_values":["bg.png","image"]},{"id":5,"type":"CLIPTextEncode","pos":[290,-130],"size":[430,280],"flags":{},"order":16,"mode":0,"inputs":[{"localized_name":"clip","name":"clip","type":"CLIP","link":309},{"localized_name":"文本","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"条件","name":"CONDITIONING","type":"CONDITIONING","links":[38]}],"properties":{"cnr_id":"comfy-core","ver":"0.20.1","Node name for S&R":"CLIPTextEncode","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.8"}},"widgets_values":["参考图1：RN，男人，深棕色长发半束着，佩戴黑色龙形发簪与珍珠长流苏发带，身着酒红色暗纹广袖长袍，领口袖口绣精致金色凤凰纹样，外搭厚实黑色狐狸毛大氅，腰间系嵌绿玉的金纹黑色腰带，面容俊朗，仪态高贵。\n参考图2：WV，女人，乌黑长发盘成精致发髻，佩戴绿玉白花发饰与同色系水滴流苏耳坠，身着暗绿色抹胸鱼尾长裙，裙身绣立体金色花卉纹样，长裙的腰间镂空露出两侧腰部，露肩露背。外搭同色系飘逸透明广袖披帛，颈间佩戴绿玉平安扣项链，面容温婉清丽，眉眼柔和灵动。\n参考图3（场景）：烟雨朦胧的江南小镇，石板小路被雨水打湿形成镜面倒影，两侧是白墙黑瓦的建筑，黑瓦上挂着晶莹的雨珠，屋檐下悬挂着暖黄色的灯笼，街道中央有一棵枝繁叶茂的垂柳，远处是云雾缭绕的青山，整体氛围清冷诗意，充满江南水乡的韵味。\n石板小路上，WV迎面走来，双手轻轻提着裙摆，衣裙飘飘。WV走近，表情从冷淡转为微笑。\nRN迎面站着，也微微一笑，说：“这么巧，没想到会在这里遇见你”。\nWV和RN两人在石板小路上面对面站着，WV微微点头，脸颊微红，嘴角扬起浅浅的笑意，声音甜美说：“我也没想到，一起走走吧。”\n镜头拉远至中景，展示WV和RN两人的侧面全身视角。RN侧身做出邀请的手势，WV点头回应，两人并肩向街道深处走去。镜头缓缓跟拍，逐渐绕到两人身后，展示背面视角，看着他们的身影逐渐消失在烟雨朦胧的石板小路尽头，"]}],"links":[[38,5,0,7,0,"CONDITIONING"],[39,6,0,7,1,"CONDITIONING"],[43,8,0,9,3,"LATENT"],[50,15,0,16,0,"NOISE"],[52,13,0,16,2,"SAMPLER"],[57,24,0,17,2,"LATENT"],[61,25,0,19,1,"AUDIO"],[62,19,0,20,0,"VIDEO"],[65,22,0,23,1,"LATENT"],[66,16,0,24,0,"LATENT"],[67,24,1,25,0,"LATENT"],[75,30,0,28,4,"IMAGE"],[119,43,0,28,5,"INT"],[120,44,0,8,1,"INT"],[121,44,0,28,6,"INT"],[122,43,0,8,0,"INT"],[139,37,0,16,1,"GUIDER"],[149,17,2,38,0,"LATENT"],[152,9,0,17,0,"CONDITIONING"],[153,9,1,17,1,"CONDITIONING"],[154,28,0,9,4,"IMAGE"],[179,7,0,9,0,"CONDITIONING"],[180,7,1,9,1,"CONDITIONING"],[200,2